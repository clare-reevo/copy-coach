{
  "manifest_version": 3,
  "name": "Reevo Copy Coach",
  "version": "0.1.0",
  "description": "Write better, more consistent product copy — powered by Reevo's tone of voice.",
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles/content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Reevo Copy Coach"
  }
}
